<div class="wishlist-container">
  <div class="wishlist-header">
    <div class="user-info-box">
      <div class="user-avatar">使用者資訊</div>
      <div class="wishlist-display" id="wishlist-display-area">
        <h3>MY WISH LIST</h3>
        <ul id="wishlist-items-list">
          </ul>
      </div>
    </div>

    <div class="category-detail-panel" id="detail-panel">
      <h3 id="detail-title">請選擇類別</h3>
      <div id="detail-items-container">
        </div>
    </div>
  </div>

  <div class="category-grid">
    {% for i in (1..6) %}
      <div class="category-card" onclick="showCategory({{ i }})">
        <div class="card-id">C{{ i }}</div>
        <div class="card-content">點擊查看細項</div>
      </div>
    {% endfor %}
  </div>

  <hr>

  <div class="recommendation-section">
    <h2>推薦商品</h2>
    <div class="product-grid" id="recommendation-grid">
      {% for product in collections.all.products limit: 12 %}
        <div class="product-item" data-product-id="{{ product.id }}" id="rec-{{ product.id }}">
          <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
          <p>{{ product.title }}</p>
          <button onclick="addToWishlist('{{ product.id }}', '{{ product.title }}', '{{ product.featured_image | img_url: 'small' }}')">Add</button>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .wishlist-container { max-width: 1200px; margin: 0 auto; padding: 20px; font-family: sans-serif; }
  .wishlist-header { display: flex; gap: 20px; margin-bottom: 30px; }
  .user-info-box { flex: 2; border: 2px solid #333; padding: 15px; display: flex; gap: 20px; background: #eee; }
  .category-detail-panel { flex: 1; border: 2px solid #333; padding: 15px; background: #fff; min-height: 150px; }
  
  .category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 40px; }
  .category-card { border: 2px solid #333; height: 120px; display: flex; flex-direction: column; cursor: pointer; padding: 10px; background: #ddd; }
  .category-card:hover { background: #ccc; }

  .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .product-item { border: 1px solid #eee; padding: 10px; text-align: center; }
  .product-item img { max-width: 100%; }
  
  /* 隱藏已收藏項目 */
  .is-hidden { display: none !important; }
  
  .wishlist-item-row { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ccc; padding: 5px 0; }
  .del-btn { color: red; cursor: pointer; border: none; background: none; }
</style>

<script>
  // 模擬 C1-C6 的細項資料 (實務上可改為讀取 Collection)
  const categoryData = {
    1: { title: "套筒 3/8 組", items: [{id: 'k1', name: '3/8接頭'}, {id: 'k2', name: '長套筒'}] },
    2: { title: "扳手類", items: [{id: 'k3', name: '扭力扳手'}, {id: 'k4', name: '開口扳手'}] },
    // ...以此類推
  };

  function initWishlist() {
    renderWishlist();
    filterRecommendations();
  }

  // 顯示右側類別細項
  function showCategory(id) {
    const data = categoryData[id] || { title: "未定義類別", items: [] };
    document.getElementById('detail-title').innerText = data.title;
    let html = '';
    data.items.forEach(item => {
      html += `
        <div style="margin-bottom:10px; border-bottom:1px solid #eee; padding-bottom:5px;">
          <span>${item.name}</span>
          <button style="background:red; color:white; border:none; float:right;" onclick="addToWishlist('${item.id}', '${item.name}', '')">add</button>
        </div>`;
    });
    document.getElementById('detail-items-container').innerHTML = html;
  }

  // CRUD: Create - 加入收藏
  function addToWishlist(id, name, img) {
    let list = JSON.parse(localStorage.getItem('kt_wishlist')) || [];
    if (!list.find(item => item.id === id)) {
      list.push({id, name, img});
      localStorage.setItem('kt_wishlist', JSON.stringify(list));
      renderWishlist();
      filterRecommendations();
    }
  }

  // CRUD: Read - 渲染收藏清單
  function renderWishlist() {
    const list = JSON.parse(localStorage.getItem('kt_wishlist')) || [];
    const container = document.getElementById('wishlist-items-list');
    container.innerHTML = list.map(item => `
      <li class="wishlist-item-row">
        <span>${item.name}</span>
        <button class="del-btn" onclick="removeFromWishlist('${item.id}')">✕</button>
      </li>
    `).join('');
  }

  // CRUD: Delete - 移除收藏
  function removeFromWishlist(id) {
    let list = JSON.parse(localStorage.getItem('kt_wishlist')) || [];
    list = list.filter(item => item.id !== id);
    localStorage.setItem('kt_wishlist', JSON.stringify(list));
    renderWishlist();
    filterRecommendations();
  }

  // 自動排除已有的項目 ID
  function filterRecommendations() {
    const list = JSON.parse(localStorage.getItem('kt_wishlist')) || [];
    const savedIds = list.map(item => item.id);
    
    document.querySelectorAll('.product-item').forEach(el => {
      const pid = el.getAttribute('data-product-id');
      if (savedIds.includes(pid)) {
        el.classList.add('is-hidden');
      } else {
        el.classList.remove('is-hidden');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initWishlist);
</script>